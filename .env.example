# Optional GitHub personal access token for higher rate limits
GITHUB_TOKEN=

# Portfolio analysis provider: mock | azure-openai (defaults to mock)
PORTFOLIO_ANALYSIS_PROVIDER=mock

# Azure OpenAI configuration (required when PORTFOLIO_ANALYSIS_PROVIDER=azure-openai)
# Use AZURE_OPENAI_API_VERSION=v1 for Azure OpenAI v1 (/openai/v1/ path, no api-version query)
# Use a dated version such as 2024-10-21 for legacy Azure OpenAI API versions
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
